# ============================================================
# DEPAN EXPRESS - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values

# Environment
NODE_ENV=development

# ============================================================
# DATABASE
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=depan_express
POSTGRES_PORT=5432
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/depan_express?schema=public"

# ============================================================
# REDIS
# ============================================================
REDIS_PASSWORD=redis
REDIS_PORT=6379
REDIS_URL="redis://:redis@localhost:6379"

# ============================================================
# JWT & AUTH
# ============================================================
# Generate with: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================
# STRIPE
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================================
# AWS S3 (or S3-compatible)
# ============================================================
AWS_REGION="eu-west-3"
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_S3_BUCKET="depan-express"
AWS_S3_ENDPOINT="http://localhost:9000"  # Leave empty for AWS, or set for S3-compatible services

# ============================================================
# MINIO (Development)
# ============================================================
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# ============================================================
# FIREBASE (Push Notifications)
# ============================================================
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# ============================================================
# GOOGLE MAPS
# ============================================================
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ============================================================
# SMS PROVIDER (Twilio)
# ============================================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ============================================================
# EMAIL PROVIDER (SendGrid / SMTP)
# ============================================================
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@depan-express.fr"
EMAIL_FROM_NAME="Depan Express"

# SMTP (MailHog for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# ============================================================
# API CONFIGURATION
# ============================================================
API_PORT=3000
API_HOST="0.0.0.0"
API_PREFIX="api/v1"
CORS_ORIGINS="http://localhost:3001,http://localhost:8081,http://localhost:8082"

# ============================================================
# ADMIN WEB
# ============================================================
ADMIN_PORT=3001
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"

# ============================================================
# MOBILE APPS
# ============================================================
EXPO_PUBLIC_API_URL="http://localhost:3000/api/v1"
EXPO_PUBLIC_WS_URL="ws://localhost:3000"

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_TTL=60
RATE_LIMIT_AUTH_MAX=5

# ============================================================
# LOGGING & MONITORING
# ============================================================
LOG_LEVEL="debug"  # debug, info, warn, error
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# ============================================================
# SECURITY
# ============================================================
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ============================================================
# FEATURE FLAGS
# ============================================================
FEATURE_2FA_ENABLED=true
FEATURE_SMS_VERIFICATION=true
FEATURE_EMAIL_VERIFICATION=true

# ============================================================
# DEVELOPMENT TOOLS
# ============================================================
ADMINER_PORT=8080
