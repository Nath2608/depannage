# ============================================================
# DEPAN EXPRESS - Production Environment Variables
# ============================================================
# Copy this file to .env.production and fill in the values
# NEVER commit this file with real credentials!

# Environment
NODE_ENV=production

# ============================================================
# DATABASE
# ============================================================
# Use a managed PostgreSQL service (AWS RDS, Google Cloud SQL, etc.)
DATABASE_URL="postgresql://user:password@db.example.com:5432/depan_express?schema=public&sslmode=require"

# ============================================================
# REDIS
# ============================================================
# Use a managed Redis service (AWS ElastiCache, Redis Cloud, etc.)
REDIS_URL="rediss://:password@redis.example.com:6379"

# ============================================================
# JWT & AUTH
# ============================================================
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_TO_A_VERY_STRONG_SECRET_IN_PRODUCTION"
JWT_REFRESH_SECRET="CHANGE_ME_TO_ANOTHER_VERY_STRONG_SECRET"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ============================================================
# STRIPE
# ============================================================
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================================
# AWS S3
# ============================================================
AWS_REGION="eu-west-3"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="depan-express-prod"
# Leave empty for real AWS S3
AWS_S3_ENDPOINT=""

# ============================================================
# FIREBASE (Push Notifications)
# ============================================================
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# ============================================================
# GOOGLE MAPS
# ============================================================
GOOGLE_MAPS_API_KEY=""

# ============================================================
# SMS PROVIDER (Twilio)
# ============================================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ============================================================
# EMAIL PROVIDER (SendGrid)
# ============================================================
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@depan-express.fr"
EMAIL_FROM_NAME="Depan Express"

# ============================================================
# API CONFIGURATION
# ============================================================
API_PORT=3000
API_HOST="0.0.0.0"
CORS_ORIGINS="https://admin.depanexpress.fr,https://depanexpress.fr"

# ============================================================
# ADMIN WEB
# ============================================================
NEXT_PUBLIC_API_URL="https://api.depanexpress.fr/api/v1"

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_TTL=60
RATE_LIMIT_AUTH_MAX=5

# ============================================================
# LOGGING & MONITORING
# ============================================================
LOG_LEVEL="info"
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"

# ============================================================
# SECURITY
# ============================================================
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ============================================================
# FEATURE FLAGS
# ============================================================
FEATURE_2FA_ENABLED=true
FEATURE_SMS_VERIFICATION=true
FEATURE_EMAIL_VERIFICATION=true
